{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "dockerfile": {
    "managerFilePatterns": [
      "/(^|/)Containerfile$/"
    ]
  },
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["quay.io/almalinuxorg/almalinux-bootc-rpi"],
      "schedule": ["* 2-5 * * 1-5"],
      "groupName": "AlmaLinux bootc RPi base image"
    },
    {
      "matchUpdateTypes": ["digest"],
      "automerge": false
    }
  ],
  "timezone": "America/Chicago"
}
